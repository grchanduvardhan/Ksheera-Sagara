<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Cow"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Cow Name *" android:textSize="13sp" android:textColor="#757575"/>
        <EditText android:id="@+id/etCowName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="e.g. Lakshmi"
            android:inputType="textCapWords" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Breed" android:textSize="13sp" android:textColor="#757575"/>
        <EditText android:id="@+id/etBreed" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="e.g. HF, Jersey, Gir"
            android:inputType="textCapWords" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tag / Ear Number" android:textSize="13sp" android:textColor="#757575"/>
        <EditText android:id="@+id/etTagNumber" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="e.g. KA-001"
            android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Save Cow"
            android:backgroundTint="#E65100"/>
    </LinearLayout>
</ScrollView>
