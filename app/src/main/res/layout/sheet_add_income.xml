<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Milk Entry"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Date *" android:textSize="13sp" android:textColor="#757575"/>
        <EditText android:id="@+id/etDate" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:focusable="false"
            android:clickable="true" android:hint="Select date"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Liters *" android:textSize="13sp" android:textColor="#757575"/>
                <EditText android:id="@+id/etLiters" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                    android:hint="e.g. 5.5"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Fat % *" android:textSize="13sp" android:textColor="#757575"/>
                <EditText android:id="@+id/etFat" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                    android:hint="e.g. 4.5"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SNF %" android:textSize="13sp" android:textColor="#757575"/>
                <EditText android:id="@+id/etSnf" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                    android:hint="e.g. 8.5"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rate/Liter *" android:textSize="13sp" android:textColor="#757575"/>
                <EditText android:id="@+id/etRate" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                    android:hint="₹ per liter"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Total Payment *" android:textSize="13sp" android:textColor="#757575"/>
        <EditText android:id="@+id/etTotalPayment" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:inputType="numberDecimal"
            android:hint="Auto-calculated or enter manually" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Session" android:textSize="13sp" android:textColor="#757575"/>
        <Spinner android:id="@+id/spinnerSession" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Assign to Cow" android:textSize="13sp" android:textColor="#757575"/>
        <Spinner android:id="@+id/spinnerCow" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Save Entry"
            android:backgroundTint="#2E7D32"/>
    </LinearLayout>
</ScrollView>
